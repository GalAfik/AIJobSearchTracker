<Window x:Class="JobSearchTracker.Views.JobDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:JobSearchTracker.Models"
        Title="Job Details" Height="700" Width="800"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,5,0,3"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <!-- Basic Information Tab -->
            <TabItem Header="Basic Information">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock Text="Company Name:"/>
                        <TextBox x:Name="CompanyNameTextBox"/>

                        <TextBlock Text="Job Title:"/>
                        <TextBox x:Name="JobTitleTextBox"/>

                        <TextBlock Text="Job URL:"/>
                        <TextBox x:Name="JobUrlTextBox"/>

                        <TextBlock Text="Location:"/>
                        <TextBox x:Name="LocationTextBox"/>

                        <TextBlock Text="Salary Range:"/>
                        <TextBox x:Name="SalaryRangeTextBox"/>

                        <TextBlock Text="Date Posted:"/>
                        <DatePicker x:Name="DatePostedPicker"/>

                        <TextBlock Text="Date Applied:"/>
                        <DatePicker x:Name="DateAppliedPicker"/>

                        <TextBlock Text="Application Platform:"/>
                        <ComboBox x:Name="PlatformComboBox"/>

                        <TextBlock Text="Status:"/>
                        <ComboBox x:Name="StatusComboBox"/>

                        <TextBlock Text="Description:"/>
                        <TextBox x:Name="DescriptionTextBox" 
                                 TextWrapping="Wrap" 
                                 AcceptsReturn="True"
                                 Height="100"
                                 VerticalScrollBarVisibility="Auto"/>

                        <TextBlock Text="Notes:"/>
                        <TextBox x:Name="NotesTextBox" 
                                 TextWrapping="Wrap" 
                                 AcceptsReturn="True"
                                 Height="100"
                                 VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Interviews Tab -->
            <TabItem Header="Interviews">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="InterviewsDataGrid"
                              Grid.Row="0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              Margin="0,0,0,10">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Round" Binding="{Binding Round}" Width="60"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding InterviewType}" Width="100"/>
                            <DataGridTextColumn Header="Date/Time" Binding="{Binding InterviewDateTime, StringFormat='MM/dd/yyyy HH:mm'}" Width="140"/>
                            <DataGridTextColumn Header="Interviewer" Binding="{Binding InterviewerName}" Width="*"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding InterviewerEmail}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Add Interview" Width="120" Height="30" Margin="0,0,10,0" Click="AddInterviewButton_Click"/>
                        <Button Content="Edit Interview" Width="120" Height="30" Margin="0,0,10,0" Click="EditInterviewButton_Click"/>
                        <Button Content="Remove Interview" Width="120" Height="30" Click="RemoveInterviewButton_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Contacts Tab -->
            <TabItem Header="Contacts">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="ContactsDataGrid"
                              Grid.Row="0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              Margin="0,0,0,10">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                            <DataGridTextColumn Header="Position" Binding="{Binding Position}" Width="*"/>
                            <DataGridTemplateColumn Header="Actions" Width="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Email" Width="60" Height="25" Margin="2" Click="EmailContactButton_Click"/>
                                            <Button Content="Gmail" Width="60" Height="25" Margin="2" Click="GmailContactButton_Click"/>
                                            <Button Content="Outlook" Width="60" Height="25" Margin="2" Click="OutlookContactButton_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Add Contact" Width="120" Height="30" Margin="0,0,10,0" Click="AddContactButton_Click"/>
                        <Button Content="Edit Contact" Width="120" Height="30" Margin="0,0,10,0" Click="EditContactButton_Click"/>
                        <Button Content="Remove Contact" Width="120" Height="30" Click="RemoveContactButton_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Save" Width="80" Height="30" Margin="0,0,10,0" Click="SaveButton_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="80" Height="30" Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
