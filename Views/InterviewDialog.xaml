<Window x:Class="JobSearchTracker.Views.InterviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Interview Details" Height="500" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,5,0,3"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Round Number:"/>
                <TextBox x:Name="RoundTextBox"/>

                <TextBlock Text="Interview Type (e.g., Phone, Video, In-Person, Technical):"/>
                <TextBox x:Name="InterviewTypeTextBox"/>

                <TextBlock Text="Interview Date and Time:"/>
                <DatePicker x:Name="InterviewDatePicker" Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Time:" FontWeight="Normal" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="InterviewTimeTextBox" Width="100" Text="09:00"/>
                </StackPanel>

                <TextBlock Text="Interviewer Name:"/>
                <TextBox x:Name="InterviewerNameTextBox"/>

                <TextBlock Text="Interviewer Email:"/>
                <TextBox x:Name="InterviewerEmailTextBox"/>

                <TextBlock Text="Outcome:"/>
                <TextBox x:Name="OutcomeTextBox"/>

                <TextBlock Text="Notes:"/>
                <TextBox x:Name="NotesTextBox" 
                         TextWrapping="Wrap" 
                         AcceptsReturn="True"
                         Height="100"
                         VerticalScrollBarVisibility="Auto"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Save" Width="80" Height="30" Margin="0,0,10,0" Click="SaveButton_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="80" Height="30" Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
