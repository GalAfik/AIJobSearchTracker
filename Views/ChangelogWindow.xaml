<Window x:Class="JobSearchTracker.Views.ChangelogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="What's New - Job Search Tracker" Height="650" Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="📋 Changelog &amp; Release Notes" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="{DynamicResource AccentBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Track all improvements and changes to Job Search Tracker" 
                       FontSize="12" 
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Scrollable Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Version 0.1.3 -->
                <Border Background="{DynamicResource SecondaryBackgroundBrush}" 
                        CornerRadius="8" 
                        Padding="20" 
                        Margin="0,0,0,15">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Version 0.1.3" 
                                       FontSize="20" 
                                       FontWeight="Bold" 
                                       Foreground="{DynamicResource AccentBrush}"/>
                            <Border Background="#28A745" 
                                    CornerRadius="3" 
                                    Padding="6,2" 
                                    Margin="10,0,0,0">
                                <TextBlock Text="Latest" 
                                           FontSize="10" 
                                           Foreground="White" 
                                           FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="Released: March 28, 2026" 
                                   FontSize="11" 
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,0,0,15"/>

                        <!-- New Features -->
                        <TextBlock Text="✨ New Features" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Margin="0,0,0,8"/>
                        <StackPanel Margin="15,0,0,15">
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• "/>
                                <Run Text="Unsaved Changes Warning:" FontWeight="SemiBold"/>
                                <Run Text=" Application now warns you when closing with unsaved changes"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="15,2,0,8" FontSize="11">
                                <Run Text="When you try to close the application with unsaved changes, a dialog will prompt you to save, discard, or cancel. Prevents accidental data loss."/>
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• "/>
                                <Run Text="Auto-Save After Import:" FontWeight="SemiBold"/>
                                <Run Text=" New preference option to automatically save after importing files"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="15,2,0,8" FontSize="11">
                                <Run Text="Enable in Preferences → Appearance → File Operations. When importing CSV files into an existing saved project, the project will automatically save after import."/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Improvements -->
                        <TextBlock Text="⚡ Improvements" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Margin="0,0,0,8"/>
                        <StackPanel Margin="15,0,0,15">
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Tracks unsaved changes across all job operations (add, edit, delete, import)"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Clear visual feedback when project has unsaved changes"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Prevents data loss from accidental application closure"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Technical Details -->
                        <TextBlock Text="🔧 Technical Changes" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Margin="0,0,0,8"/>
                        <StackPanel Margin="15,0,0,0">
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Added HasUnsavedChanges property to MainViewModel with change tracking"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Added AutoSaveAfterImport property to UserPreferences model"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Implemented MainWindow.Closing event handler for unsaved changes check"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Added CheckUnsavedChanges method with Yes/No/Cancel dialog logic"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Version 0.1.2 -->
                <Border Background="{DynamicResource SecondaryBackgroundBrush}" 
                        CornerRadius="8" 
                        Padding="20" 
                        Margin="0,0,0,15">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Version 0.1.2" 
                                       FontSize="20" 
                                       FontWeight="Bold" 
                                       Foreground="{DynamicResource AccentBrush}"/>
                        </StackPanel>
                        <TextBlock Text="Released: March 28, 2026" 
                                   FontSize="11" 
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,0,0,15"/>

                        <!-- Bug Fixes -->
                        <TextBlock Text="🐛 Critical Bug Fix"
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Margin="0,0,0,8"/>
                        <StackPanel Margin="15,0,0,15">
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• "/>
                                <Run Text="Fixed loading existing project files not displaying jobs" FontWeight="SemiBold"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="15,2,0,3" FontSize="11">
                                <Run Text="Issue: When opening a saved project file, the project would load successfully but the job list remained empty"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="15,0,0,8" FontSize="11">
                                <Run Text="Solution: Fixed ComboBox bindings to use SelectedValue instead of Text, ensuring filter values properly sync with UI controls"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Technical Details -->
                        <TextBlock Text="🔧 Technical Changes" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Margin="0,0,0,8"/>
                        <StackPanel Margin="15,0,0,0">
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Changed Status filter ComboBox from Text binding to SelectedValue binding with SelectedValuePath"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Changed Sort By ComboBox from Text binding to SelectedValue binding with SelectedValuePath"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Ensures filter reset code properly synchronizes with UI controls when loading projects"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Version 0.1.1 -->
                <Border Background="{DynamicResource SecondaryBackgroundBrush}" 
                        CornerRadius="8" 
                        Padding="20" 
                        Margin="0,0,0,15">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Version 0.1.1" 
                                       FontSize="20" 
                                       FontWeight="Bold" 
                                       Foreground="{DynamicResource AccentBrush}"/>
                        </StackPanel>
                        <TextBlock Text="Released: March 28, 2026" 
                                   FontSize="11" 
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,0,0,15"/>

                        <!-- Bug Fixes -->
                        <TextBlock Text="🐛 Bug Fixes"
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Margin="0,0,0,8"/>
                        <StackPanel Margin="15,0,0,15">
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• "/>
                                <Run Text="Fixed Compact View mode not switching when checkbox is toggled" FontWeight="SemiBold"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="15,2,0,3" FontSize="11">
                                <Run Text="Issue: The Compact View checkbox would check/uncheck but the job list view wouldn't change"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="15,0,0,8" FontSize="11">
                                <Run Text="Solution: Made UserPreferences property in MainViewModel raise PropertyChanged events when updated, allowing UI bindings to detect changes"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Improvements -->
                        <TextBlock Text="⚡ Improvements" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Margin="0,0,0,8"/>
                        <StackPanel Margin="15,0,0,0">
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Enhanced code documentation across all ViewModels and Models"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Improved property change notifications for better UI responsiveness"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Updated Changelog window to show version history"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Version 0.1.0 -->
                <Border Background="{DynamicResource SecondaryBackgroundBrush}" 
                        CornerRadius="8" 
                        Padding="20" 
                        Margin="0,0,0,15">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Version 0.1.0" 
                                       FontSize="20" 
                                       FontWeight="Bold" 
                                                       Foreground="{DynamicResource AccentBrush}"/>
                                       </StackPanel>
                                       <TextBlock Text="Released: March 27, 2026" 
                                                  FontSize="11" 
                                                  Foreground="{DynamicResource SecondaryTextBrush}"
                                                  Margin="0,0,0,15"/>

                                       <!-- New Features -->
                                       <TextBlock Text="✨ New Features" 
                                                  FontSize="14" 
                                                  FontWeight="Bold" 
                                                  Foreground="{DynamicResource PrimaryTextBrush}"
                                                  Margin="0,0,0,8"/>
                                       <StackPanel Margin="15,0,0,15">
                                           <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                               <Run Text="• "/>
                                               <Run Text="Analytics Dashboard:" FontWeight="Bold"/>
                                <Run Text=" Comprehensive analytics with 15+ metrics including response rates, time-based insights, platform statistics, and activity patterns"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• "/>
                                <Run Text="AI-Powered Job Scraping:" FontWeight="Bold"/>
                                <Run Text=" Extract job details from URLs using Claude, OpenAI, or Gemini AI"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• "/>
                                <Run Text="CSV Import/Export:" FontWeight="Bold"/>
                                <Run Text=" Import jobs from CSV files or export your entire project to CSV format"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• "/>
                                <Run Text="Compact View Mode:" FontWeight="Bold"/>
                                <Run Text=" Space-efficient job listing option for viewing more jobs at once"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• "/>
                                <Run Text="Motivational Messages:" FontWeight="Bold"/>
                                <Run Text=" 50+ randomized encouraging messages in the title bar that change with each launch"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• "/>
                                <Run Text="Welcome Dialog:" FontWeight="Bold"/>
                                <Run Text=" Interactive introduction for new users with quick start guide and feature highlights"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• "/>
                                <Run Text="Sample Files:" FontWeight="Bold"/>
                                <Run Text=" Included sample project and CSV files to help you get started quickly"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• "/>
                                <Run Text="GitHub Sponsors Integration:" FontWeight="Bold"/>
                                <Run Text=" Support the project directly from the Help menu"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Bug Fixes -->
                        <TextBlock Text="🐛 Bug Fixes" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Margin="0,0,0,8"/>
                        <StackPanel Margin="15,0,0,15">
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Fixed issue where opening existing project files would show success message but not display jobs"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Fixed New Project dialog where Create/Cancel buttons were cut off or not visible"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Fixed namespace issues with structured address input form"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Resolved nullable DateTime handling in analytics calculations"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Improvements -->
                        <TextBlock Text="⚡ Improvements" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Margin="0,0,0,8"/>
                        <StackPanel Margin="15,0,0,15">
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Enhanced Dark Theme with better color contrast and visual hierarchy"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Improved Light Theme with modern, clean aesthetics"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Inline editing support for job details in the main window"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Structured address input form for home address in preferences"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Better error handling and user feedback throughout the application"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Filters now automatically reset when loading a new project"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Documentation -->
                        <TextBlock Text="📚 Documentation" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Margin="0,0,0,8"/>
                        <StackPanel Margin="15,0,0,0">
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Comprehensive README with feature overview and architecture details"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• AI Feature Guide with step-by-step setup instructions"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Getting Started guide for new users"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Sample files documentation with import/usage instructions"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• MIT License for open-source distribution"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Legal disclaimers and warranty information"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Future Plans -->
                <Border Background="{DynamicResource SecondaryBackgroundBrush}" 
                        CornerRadius="8" 
                        Padding="20" 
                        Margin="0,0,0,0">
                    <StackPanel>
                        <TextBlock Text="🚀 Coming Soon" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource AccentBrush}"
                                   Margin="0,0,0,10"/>
                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,3">
                            <Run Text="• "/>
                            <Run Text="Reminder notifications for follow-ups and interviews"/>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,3">
                            <Run Text="• "/>
                            <Run Text="Advanced statistics dashboard with charts and graphs"/>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,3">
                            <Run Text="• "/>
                            <Run Text="Cloud sync capabilities for multi-device access"/>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,3">
                            <Run Text="• "/>
                            <Run Text="Mobile companion app"/>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,3">
                            <Run Text="• "/>
                            <Run Text="Integration with LinkedIn and Indeed for direct imports"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Margin="0,15,0,0">
            <Separator Margin="0,0,0,15"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="💡 Have a suggestion? " 
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock VerticalAlignment="Center">
                    <Hyperlink NavigateUri="https://github.com/GalAfik/AIJobSearchTracker/issues" 
                               RequestNavigate="Hyperlink_RequestNavigate"
                               Foreground="{DynamicResource AccentBrush}">
                        Report it on GitHub
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
            <Button Content="Close" 
                    Width="100" 
                    Height="35" 
                    Margin="0,15,0,0"
                    Click="CloseButton_Click"
                    IsDefault="True"
                    Style="{DynamicResource ModernButton}"
                    HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
