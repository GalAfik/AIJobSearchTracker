<Window x:Class="JobSearchTracker.Views.ChangelogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="What's New - Job Search Tracker" Height="650" Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="📋 Changelog &amp; Release Notes" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="{DynamicResource AccentBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Track all improvements and changes to Job Search Tracker" 
                       FontSize="12" 
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Scrollable Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Version 0.1.6 -->
                <Border Background="{DynamicResource SecondaryBackgroundBrush}" 
                        CornerRadius="8" 
                        Padding="20" 
                        Margin="0,0,0,15">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Version 0.1.6" 
                                       FontSize="20" 
                                       FontWeight="Bold" 
                                       Foreground="{DynamicResource AccentBrush}"/>
                            <Border Background="#28A745" 
                                    CornerRadius="3" 
                                    Padding="6,2" 
                                    Margin="10,0,0,0">
                                <TextBlock Text="Latest" 
                                           FontSize="10" 
                                           Foreground="White" 
                                           FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="Released: March 31, 2026" 
                                   FontSize="11" 
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,0,0,15"/>

                        <!-- New Features -->
                        <TextBlock Text="✨ New Features" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Margin="0,0,0,8"/>
                        <StackPanel Margin="15,0,0,15">
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• "/>
                                <Run Text="Unemployment Report Export:" FontWeight="SemiBold"/>
                                <Run Text=" Generate government-ready job application reports"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="15,2,0,8" FontSize="11">
                                <Run Text="New export option specifically designed for unemployment reporting requirements. Generates a simple Excel document with 4 columns (Company Name, Job Title, Date Applied, Website) containing only jobs you applied to within the last 7 days. Perfect for weekly unemployment claim documentation. Access via File → Export Unemployment Report."/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Improvements -->
                        <TextBlock Text="⚡ Improvements" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Margin="0,0,0,8"/>
                        <StackPanel Margin="15,0,0,15">
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Menu reorganization: Import from CSV moved from File menu to Job menu"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Improved menu logic: File menu for project operations, Job menu for job-specific actions"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Automatic 7-day date filtering from current date for unemployment reports"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Filters only 'Applied' status jobs for accurate reporting"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Auto-generated filename with project name and date stamp"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Success message shows count of exported jobs"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Technical Details -->
                        <TextBlock Text="🔧 Technical Changes" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Margin="0,0,0,8"/>
                        <StackPanel Margin="15,0,0,0">
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Added ExportUnemploymentReportCommand to MainViewModel"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Implemented ExportUnemploymentReport() method with date filtering logic"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Added ExportUnemploymentReport() to ExportService with simplified Excel format"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Date filtering: DateTime.Now.AddDays(-7) with nullable DateTime handling"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Menu items reorganized in MainWindow.xaml for better UX"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Version 0.1.5 -->
                <Border Background="{DynamicResource SecondaryBackgroundBrush}" 
                        CornerRadius="8" 
                        Padding="20" 
                        Margin="0,0,0,15">
