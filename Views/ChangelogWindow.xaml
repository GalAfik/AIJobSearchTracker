                                <Run Text="Application now automatically saves your filter and sort preferences when you change them. When you restart, your Status filter and Sort By selections are restored exactly as you left them, saving time and providing a consistent experience."/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Improvements -->
                        <TextBlock Text="⚡ Improvements" 
