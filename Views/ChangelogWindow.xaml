                            <TextBlock Text="Version 0.1.5" 
                                       FontSize="20" 
                                       FontWeight="Bold" 
                                       Foreground="{DynamicResource AccentBrush}"/>
                        </StackPanel>
                        <TextBlock Text="Released: March 30, 2026"
                                   FontSize="11" 
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,0,0,15"/>

                        <!-- New Features -->
                        <TextBlock Text="✨ New Features" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Margin="0,0,0,8"/>
                        <StackPanel Margin="15,0,0,15">
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• "/>
                                <Run Text="Software Update Checker:" FontWeight="SemiBold"/>
                                <Run Text=" Automatic detection of new versions"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="15,2,0,8" FontSize="11">
                                <Run Text="Application now checks www.galafik.com for updates on startup. When a new version is available, a non-intrusive notification appears in the footer with a clickable link to download. Check can be disabled in Preferences → Appearance. Silent failure ensures the check never disrupts your workflow."/>
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• "/>
                                <Run Text="Suppress Warning Messages:" FontWeight="SemiBold"/>
                                <Run Text=" Optional suppression of success confirmations"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="15,2,0,8" FontSize="11">
                                <Run Text="Power users can now enable 'Suppress warning messages' in Preferences → Appearance to hide informational success dialogs (saves, exports, imports). Critical errors and delete confirmations always show regardless of this setting. Default is OFF (warnings shown) for safety."/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Improvements -->
                        <TextBlock Text="⚡ Improvements" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Margin="0,0,0,8"/>
                        <StackPanel Margin="15,0,0,15">
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Non-modal update notification in footer (bottom-left corner)"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Semantic version comparison for accurate update detection"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Cleaner workflow for frequent operations when warnings suppressed"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• User control over update checks and notification preferences"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Technical Details -->
                        <TextBlock Text="🔧 Technical Changes" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Margin="0,0,0,8"/>
                        <StackPanel Margin="15,0,0,0">
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Added UpdateService with website scraping and regex pattern matching"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Implemented CheckForUpdates and SuppressWarnings user preferences"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• 10-second timeout on update checks with silent failure handling"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3">
                                <Run Text="• Conditional message display pattern for suppressible warnings"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Version 0.1.4 -->
