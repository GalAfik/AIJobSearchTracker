<Window x:Class="JobSearchTracker.Views.AddJobFromUrlDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🤖 Add Job from URL (AI-Powered)" Height="400" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="🤖 AI-Powered Job Scraping" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="Paste a job posting URL and let AI extract the details automatically" 
                       FontSize="12" 
                       Foreground="{DynamicResource SecondaryTextBrush}" 
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- URL Input -->
        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="Job Posting URL:" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="UrlTextBox" 
                     Style="{DynamicResource ModernTextBox}"
                     Padding="10"
                     FontSize="13"
                     Text="https://"/>
        </StackPanel>

        <!-- AI Provider Selection -->
        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="AI Provider:" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox x:Name="AiProviderComboBox" 
                      Style="{DynamicResource ModernComboBox}"
                      SelectionChanged="AiProviderComboBox_SelectionChanged">
                <ComboBoxItem Content="Claude (Anthropic)" Tag="Claude" IsSelected="True"/>
                <ComboBoxItem Content="ChatGPT (OpenAI)" Tag="OpenAI"/>
                <ComboBoxItem Content="Gemini (Google)" Tag="Gemini"/>
            </ComboBox>
            <TextBlock x:Name="ApiKeyStatusTextBlock" 
                       Margin="0,5,0,0" 
                       FontSize="11" 
                       Foreground="{DynamicResource SecondaryTextBrush}"/>
        </StackPanel>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Content="🚀 Scrape Job" 
                    x:Name="ScrapeButton"
                    Click="ScrapeButton_Click" 
                    Style="{DynamicResource ModernButton}"
                    Width="150"/>
            <Button Content="⚙️ Configure API Keys" 
                    Click="ConfigureApiKeysButton_Click" 
                    Style="{DynamicResource ModernButton}"
                    Margin="10,0,0,0"
                    Width="150"/>
        </StackPanel>

        <!-- Status/Progress Area -->
        <Border Grid.Row="4" 
                Background="{DynamicResource SecondaryBackgroundBrush}" 
                BorderBrush="{DynamicResource BorderBrush}" 
                BorderThickness="1" 
                CornerRadius="6" 
                Padding="15">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock x:Name="StatusTextBlock" 
                               TextWrapping="Wrap" 
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               FontSize="12">
                        <Run Text="Ready to scrape. Enter a job URL and click 'Scrape Job'."/>
                    </TextBlock>

                    <ProgressBar x:Name="ProgressBar" 
                                 Height="4" 
                                 Margin="0,10,0,0" 
                                 IsIndeterminate="False"
                                 Visibility="Collapsed"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Bottom Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Close" Width="100" Height="35" Click="CloseButton_Click" Style="{DynamicResource ModernButton}"/>
        </StackPanel>
    </Grid>
</Window>
