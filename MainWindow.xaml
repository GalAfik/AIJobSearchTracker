<Window x:Class="JobSearchTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:JobSearchTracker"
        xmlns:models="clr-namespace:JobSearchTracker.Models"
        mc:Ignorable="d"
        Title="Job Search Tracker" Height="850" Width="1400"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <!-- Normal View Template -->
        <DataTemplate x:Key="NormalJobTemplate">
            <Border Padding="12" 
                    BorderBrush="{DynamicResource BorderBrush}" 
                    BorderThickness="0,0,0,1"
                    CornerRadius="4"
                    Margin="2">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
                        <Setter Property="Opacity" Value="1.0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRejected}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource RejectedBackgroundBrush}"/>
                                <Setter Property="Opacity" Value="0.6"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ListItemHoverBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="{Binding CompanyName}" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock Text="{Binding JobTitle}" FontSize="12" Foreground="{DynamicResource AccentBrush}" Margin="0,2,0,0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Border Background="{DynamicResource AccentBrush}" 
                                CornerRadius="3" 
                                Padding="6,2" 
                                Margin="0,0,8,0">
                            <TextBlock Text="{Binding Status}" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                        </Border>
                        <TextBlock Text="{Binding Location}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="💼 " FontSize="10"/>
                        <TextBlock Text="{Binding Interviews.Count}" FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Text=" interviews" FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}" Margin="2,0,15,0"/>
                        <TextBlock Text="👤 " FontSize="10"/>
                        <TextBlock Text="{Binding Contacts.Count}" FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Text=" contacts" FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}" Margin="2,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Compact View Template -->
        <DataTemplate x:Key="CompactJobTemplate">
            <Border Padding="8,6" 
                    BorderBrush="{DynamicResource BorderBrush}" 
                    BorderThickness="0,0,0,1"
                    Margin="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
                        <Setter Property="Opacity" Value="1.0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRejected}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource RejectedBackgroundBrush}"/>
                                <Setter Property="Opacity" Value="0.6"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ListItemHoverBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding CompanyName}" FontWeight="Bold" FontSize="12" Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock Text=" • " FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="4,0"/>
                    <TextBlock Text="{Binding JobTitle}" FontSize="12" Foreground="{DynamicResource AccentBrush}"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Menu Grid.Row="0" Background="{DynamicResource SecondaryBackgroundBrush}">
            <MenuItem Header="_File" Foreground="{DynamicResource PrimaryTextBrush}">
                <MenuItem Header="_New Project" Command="{Binding NewProjectCommand}"/>
                <MenuItem Header="_Open Project..." Command="{Binding LoadProjectCommand}"/>
                <MenuItem Header="_Import from CSV..." Command="{Binding ImportCsvCommand}"/>
                <MenuItem Header="_Save Project" Command="{Binding SaveProjectCommand}"/>
                <MenuItem Header="Save Project _As..." Command="{Binding SaveProjectAsCommand}"/>
                <Separator/>
                <MenuItem Header="_Export to Excel..." Command="{Binding ExportToExcelCommand}"/>
                <MenuItem Header="Export to _CSV..." Command="{Binding ExportToCsvCommand}"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="ExitMenuItem_Click"/>
            </MenuItem>
            <MenuItem Header="_Job" Foreground="{DynamicResource PrimaryTextBrush}">
                <MenuItem Header="_Add Job" Command="{Binding AddJobCommand}"/>
                <MenuItem Header="🤖 Add Job from URL (AI)" Command="{Binding AddJobFromUrlCommand}"/>
                <MenuItem Header="_Edit Job" Command="{Binding EditJobCommand}"/>
                <MenuItem Header="_Delete Job" Command="{Binding DeleteJobCommand}"/>
            </MenuItem>
            <MenuItem Header="_Help" Foreground="{DynamicResource PrimaryTextBrush}">
                <MenuItem Header="📊 _Analytics" Click="AnalyticsMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="_Preferences" Click="PreferencesMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="🐛 _Report a Bug" Click="ReportBugMenuItem_Click"/>
                <MenuItem Header="❤️ _Sponsor this Project" Click="SponsorButton_Click"/>
                <Separator/>
                <MenuItem Header="_About" Click="AboutMenuItem_Click"/>
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <ToolBar Grid.Row="1" Padding="10" Background="{DynamicResource SecondaryBackgroundBrush}">
            <Button Content="➕ New Project" Command="{Binding NewProjectCommand}" Style="{DynamicResource ModernButton}" Margin="0,0,5,0"/>
            <Button Content="📂 Open" Command="{Binding LoadProjectCommand}" Style="{DynamicResource ModernButton}" Margin="0,0,5,0"/>
            <Button Content="💾 Save" Command="{Binding SaveProjectCommand}" Style="{DynamicResource ModernButton}" Margin="0,0,5,0"/>
            <Separator Margin="5,0"/>
            <Button Content="➕ Add Job" Command="{Binding AddJobCommand}" Style="{DynamicResource ModernButton}" Margin="0,0,5,0"/>
            <Button Content="🤖 AI Add" Command="{Binding AddJobFromUrlCommand}" Style="{DynamicResource ModernButton}" Margin="0,0,5,0" ToolTip="Add job from URL using AI"/>
            <Button Content="✏️ Edit Job" Command="{Binding EditJobCommand}" Style="{DynamicResource ModernButton}" Margin="0,0,5,0"/>
            <Button Content="🗑️ Delete Job" Command="{Binding DeleteJobCommand}" Style="{DynamicResource ModernButton}" Margin="0,0,5,0"/>
            <Separator Margin="5,0"/>
            <Button Content="📊 Export" Command="{Binding ExportToExcelCommand}" Style="{DynamicResource ModernButton}" Margin="0,0,5,0"/>
            <Separator Margin="5,0"/>
            <CheckBox x:Name="CompactViewCheckBox" Content="📋 Compact View" 
                      IsChecked="{Binding UserPreferences.UseCompactView, Mode=TwoWay}"
                      VerticalAlignment="Center" 
                      Foreground="{DynamicResource PrimaryTextBrush}"
                      Margin="5,0"/>
            <Separator Margin="5,0"/>
            <TextBlock Text="{Binding ProjectName}" VerticalAlignment="Center" FontWeight="Bold" Margin="10,0" Foreground="{DynamicResource AccentBrush}" FontSize="14"/>
        </ToolBar>

        <!-- Main Content -->
        <Grid Grid.Row="2" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Job List -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Filter Section -->
                <GroupBox Grid.Row="0" Header="🔍 Filter &amp; Search" Margin="0,0,0,10" Padding="15" Style="{DynamicResource ModernGroupBox}">
                    <StackPanel>
                        <TextBlock Text="Search:" Margin="0,0,0,5" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" 
                                 Margin="0,0,0,15" 
                                 Style="{DynamicResource ModernTextBox}"/>

                        <TextBlock Text="Status:" Margin="0,0,0,5" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <ComboBox Text="{Binding StatusFilterText, Mode=TwoWay}" 
                                  IsEditable="False"
                                  Margin="0,0,0,15" 
                                  Style="{DynamicResource ModernComboBox}">
                            <ComboBoxItem Content="All" IsSelected="True"/>
                            <ComboBoxItem Content="Not Applied"/>
                            <ComboBoxItem Content="Applied"/>
                            <ComboBoxItem Content="Interviewed"/>
                            <ComboBoxItem Content="Offered"/>
                            <ComboBoxItem Content="Accepted"/>
                            <ComboBoxItem Content="Rejected"/>
                            <ComboBoxItem Content="Withdrawn"/>
                        </ComboBox>

                        <TextBlock Text="Sort By:" Margin="0,0,0,5" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <ComboBox Text="{Binding CurrentSortOption, Mode=TwoWay}" 
                                  IsEditable="False"
                                  Margin="0,0,0,15" 
                                  Style="{DynamicResource ModernComboBox}">
                            <ComboBoxItem Content="Date Added (Newest)" IsSelected="True"/>
                            <ComboBoxItem Content="Date Added (Oldest)"/>
                            <ComboBoxItem Content="Company Name (A-Z)"/>
                            <ComboBoxItem Content="Company Name (Z-A)"/>
                            <ComboBoxItem Content="Date Applied (Newest)"/>
                            <ComboBoxItem Content="Date Applied (Oldest)"/>
                            <ComboBoxItem Content="Status"/>
                        </ComboBox>

                        <Button Content="🔄 Clear Filter" Command="{Binding ClearFilterCommand}" Style="{DynamicResource ModernButton}"/>
                    </StackPanel>
                </GroupBox>

                <!-- Job Count -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="📋 Jobs: " Foreground="{DynamicResource SecondaryTextBrush}" FontSize="13"/>
                    <TextBlock Text="{Binding FilteredJobs.Count, Mode=OneWay}" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" FontSize="13"/>
                </StackPanel>

                <Separator Grid.Row="2" Margin="0,0,0,10"/>

                <!-- Jobs List -->
                <ListBox Grid.Row="3" 
                         x:Name="JobsListBox"
                         ItemsSource="{Binding FilteredJobs}"
                         SelectedItem="{Binding SelectedJob}"
                         MouseDoubleClick="JobsList_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <StaticResource ResourceKey="NormalJobTemplate"/>
                    </ListBox.ItemTemplate>
                    <ListBox.Style>
                        <Style TargetType="ListBox" BasedOn="{StaticResource ModernListBox}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding UserPreferences.UseCompactView}" Value="True">
                                    <Setter Property="ItemTemplate" Value="{StaticResource CompactJobTemplate}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Style>
                </ListBox>
            </Grid>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="{DynamicResource BorderBrush}"/>

            <!-- Right Panel - Job Details (Inline Editing) -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="📄 Job Details" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" x:Name="EditButtonsPanel">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedJob}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Button Content="💾 Save Changes" 
                                Click="SaveJobButton_Click"
                                Style="{DynamicResource ModernButton}" 
                                Padding="10,5" 
                                Margin="0,0,10,0"/>
                        <Button Content="🔄 Reload" 
                                Click="ReloadJobButton_Click"
                                Style="{DynamicResource ModernButton}" 
                                Padding="10,5"/>
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel DataContext="{Binding SelectedJob}" x:Name="JobDetailsPanel">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- Basic Information (Editable) -->
                        <GroupBox Header="📋 Basic Information" Margin="0,0,0,15" Padding="15" Style="{DynamicResource ModernGroupBox}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Company:" FontWeight="SemiBold" Margin="0,8" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding CompanyName, UpdateSourceTrigger=PropertyChanged}" Margin="0,8" Style="{DynamicResource ModernTextBox}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Job Title:" FontWeight="SemiBold" Margin="0,8" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding JobTitle, UpdateSourceTrigger=PropertyChanged}" Margin="0,8" Style="{DynamicResource ModernTextBox}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Location:" FontWeight="SemiBold" Margin="0,8" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                <DockPanel Grid.Row="2" Grid.Column="1" Margin="0,8">
                                    <Button Content="🗺️" 
                                            Command="{Binding DataContext.GetDirectionsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Style="{DynamicResource ModernButton}"
                                            DockPanel.Dock="Right"
                                            Margin="10,0,0,0"
                                            Padding="8,4"
                                            ToolTip="Get Directions"
                                            FontSize="11"/>
                                    <TextBox Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource ModernTextBox}"/>
                                </DockPanel>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Status:" FontWeight="SemiBold" Margin="0,8" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                <ComboBox Grid.Row="3" Grid.Column="1" 
                                          SelectedItem="{Binding Status, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="0,8"
                                          Style="{DynamicResource ModernComboBox}">
                                    <x:Static Member="models:JobStatus.NotApplied"/>
                                    <x:Static Member="models:JobStatus.Applied"/>
                                    <x:Static Member="models:JobStatus.Interviewed"/>
                                    <x:Static Member="models:JobStatus.Offered"/>
                                    <x:Static Member="models:JobStatus.Accepted"/>
                                    <x:Static Member="models:JobStatus.Rejected"/>
                                    <x:Static Member="models:JobStatus.Withdrawn"/>
                                </ComboBox>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Date Applied:" FontWeight="SemiBold" Margin="0,8" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                <DatePicker Grid.Row="4" Grid.Column="1" 
                                            SelectedDate="{Binding DateApplied, UpdateSourceTrigger=PropertyChanged}" 
                                            Margin="0,8"
                                            Padding="5"/>

                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Platform:" FontWeight="SemiBold" Margin="0,8" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                <ComboBox Grid.Row="5" Grid.Column="1" 
                                          SelectedItem="{Binding ApplicationPlatform, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="0,8"
                                          Style="{DynamicResource ModernComboBox}">
                                    <x:Static Member="models:ApplicationPlatform.LinkedInEasyApply"/>
                                    <x:Static Member="models:ApplicationPlatform.Indeed"/>
                                    <x:Static Member="models:ApplicationPlatform.Glassdoor"/>
                                    <x:Static Member="models:ApplicationPlatform.ZipRecruiter"/>
                                    <x:Static Member="models:ApplicationPlatform.Handshake"/>
                                    <x:Static Member="models:ApplicationPlatform.CompanyWebsite"/>
                                    <x:Static Member="models:ApplicationPlatform.Referral"/>
                                    <x:Static Member="models:ApplicationPlatform.Other"/>
                                </ComboBox>

                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Salary Range:" FontWeight="SemiBold" Margin="0,8" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding SalaryRange, UpdateSourceTrigger=PropertyChanged}" Margin="0,8" Style="{DynamicResource ModernTextBox}"/>

                                <TextBlock Grid.Row="7" Grid.Column="0" Text="Job URL:" FontWeight="SemiBold" Margin="0,8" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                <DockPanel Grid.Row="7" Grid.Column="1" Margin="0,8">
                                    <Button Content="🔗" 
                                            Click="OpenJobUrlButton_Click"
                                            Style="{DynamicResource ModernButton}"
                                            DockPanel.Dock="Right"
                                            Margin="10,0,0,0"
                                            Padding="8,4"
                                            ToolTip="Open URL"
                                            FontSize="11"/>
                                    <TextBox Text="{Binding JobUrl, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource ModernTextBox}"/>
                                </DockPanel>

                                <TextBlock Grid.Row="8" Grid.Column="0" Text="Description:" FontWeight="SemiBold" Margin="0,8" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Top"/>
                                <TextBox Grid.Row="8" Grid.Column="1" 
                                         Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" 
                                         Margin="0,8" 
                                         Style="{DynamicResource ModernTextBox}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="60"
                                         MaxHeight="120"
                                         VerticalScrollBarVisibility="Auto"/>
                            </Grid>
                        </GroupBox>

                        <!-- Notes (Editable) -->
                        <GroupBox Header="📝 Notes" Margin="0,0,0,15" Padding="15" Style="{DynamicResource ModernGroupBox}">
                            <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{DynamicResource ModernTextBox}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="80"
                                     MaxHeight="200"
                                     VerticalScrollBarVisibility="Auto"/>
                        </GroupBox>

                        <!-- Interviews (Inline Management) -->
                        <GroupBox Header="💼 Interviews" Margin="0,0,0,15" Padding="15" Style="{DynamicResource ModernGroupBox}">
                            <StackPanel>
                                <Button Content="➕ Add Interview" 
                                        Click="AddInterviewButton_Click"
                                        Style="{DynamicResource ModernButton}" 
                                        HorizontalAlignment="Right"
                                        Padding="10,5" 
                                        Margin="0,0,0,10"/>
                                <ListView ItemsSource="{Binding Interviews}" 
                                          x:Name="InterviewsListView"
                                          Background="Transparent" 
                                          BorderThickness="0"
                                          MouseDoubleClick="InterviewsListView_MouseDoubleClick">
                                    <ListView.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Edit Interview" Click="EditInterviewMenuItem_Click"/>
                                            <MenuItem Header="Delete Interview" Click="DeleteInterviewMenuItem_Click"/>
                                        </ContextMenu>
                                    </ListView.ContextMenu>
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Round" Width="60" DisplayMemberBinding="{Binding Round}"/>
                                            <GridViewColumn Header="Type" Width="100" DisplayMemberBinding="{Binding InterviewType}"/>
                                            <GridViewColumn Header="Date/Time" Width="140" DisplayMemberBinding="{Binding InterviewDateTime, StringFormat='MM/dd/yyyy HH:mm'}"/>
                                            <GridViewColumn Header="Interviewer" Width="150" DisplayMemberBinding="{Binding InterviewerName}"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </StackPanel>
                        </GroupBox>

                        <!-- Contacts (Inline Management) -->
                        <GroupBox Header="👤 Contacts" Margin="0,0,0,15" Padding="15" Style="{DynamicResource ModernGroupBox}">
                            <StackPanel>
                                <Button Content="➕ Add Contact" 
                                        Click="AddContactButton_Click"
                                        Style="{DynamicResource ModernButton}" 
                                        HorizontalAlignment="Right"
                                        Padding="10,5" 
                                        Margin="0,0,0,10"/>
                                <ListView ItemsSource="{Binding Contacts}" 
                                          x:Name="ContactsListView"
                                          Background="Transparent" 
                                          BorderThickness="0"
                                          MouseDoubleClick="ContactsListView_MouseDoubleClick">
                                    <ListView.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Edit Contact" Click="EditContactMenuItem_Click"/>
                                            <MenuItem Header="Delete Contact" Click="DeleteContactMenuItem_Click"/>
                                        </ContextMenu>
                                    </ListView.ContextMenu>
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Name" Width="150" DisplayMemberBinding="{Binding Name}"/>
                                            <GridViewColumn Header="Email" Width="200" DisplayMemberBinding="{Binding Email}"/>
                                            <GridViewColumn Header="Position" Width="150" DisplayMemberBinding="{Binding Position}"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>

                <!-- Empty State -->
                <TextBlock Grid.Row="1" 
                           Text="Select a job to view details"
                           FontSize="16"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedJob}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="3" 
                Background="{DynamicResource SecondaryBackgroundBrush}" 
                BorderBrush="{DynamicResource BorderBrush}" 
                BorderThickness="0,1,0,0" 
                Padding="15,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Copyright Info -->
                <TextBlock Grid.Column="1" 
                           HorizontalAlignment="Center" 
                           Foreground="{DynamicResource SecondaryTextBrush}" 
                           FontSize="11">
                    <Run Text="© 2026"/>
                    <Run Text=" Gal Afik" FontWeight="SemiBold"/>
                    <Run Text=" • Job Search Tracker v0.1.0 • All Rights Reserved"/>
                </TextBlock>

                <!-- Sponsor Button -->
                <Button Grid.Column="2" 
                        Content="❤️ Sponsor" 
                        Click="SponsorButton_Click"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Padding="15,4"
                        FontSize="11"
                        Cursor="Hand"
                        ToolTip="Support this project on GitHub Sponsors">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#EA4AAA"/>
                            <Setter Property="BorderBrush" Value="#EA4AAA"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EA4AAA"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
